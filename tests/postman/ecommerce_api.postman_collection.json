{
	"info": {
		"_postman_id": "e1c0mm3r-ce00-4ad1-9a11-ecommerceapi01",
		"name": "E-Commerce Admin Panel API",
		"description": "API test collection for the e-commerce admin panel (auth.php + products.php). Auto-generated to match the documented REST API. The original manual Postman testing and its screenshots are in 'postman work.docx' and ../../screenshots/postman/.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost/ecommerce_api/backend/api",
			"type": "string"
		},
		{
			"key": "productId",
			"value": "1",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Signup (create admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var json = pm.response.json();",
									"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
									"pm.test('has status field', function () { pm.expect(json).to.have.property('status'); });"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"action\": \"signup\",\n    \"firstName\": \"Test\",\n    \"lastName\": \"Admin\",\n    \"email\": \"admin_{{$timestamp}}@example.com\",\n    \"password\": \"TestPassword@123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/auth.php",
							"host": [ "{{baseUrl}}" ],
							"path": [ "auth.php" ]
						},
						"description": "Registers a new admin. Email uses a timestamp so it stays unique on re-runs."
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var json = pm.response.json();",
									"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
									"pm.test('returns a status', function () { pm.expect(json).to.have.property('status'); });"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"action\": \"login\",\n    \"email\": \"admin@example.com\",\n    \"password\": \"admin123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/auth.php",
							"host": [ "{{baseUrl}}" ],
							"path": [ "auth.php" ]
						},
						"description": "Logs in an admin. Use credentials of an account created via the Signup request or the signup page."
					}
				}
			]
		},
		{
			"name": "Products",
			"item": [
				{
					"name": "Get all products",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var json = pm.response.json();",
									"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
									"pm.test('status is success', function () { pm.expect(json.status).to.eql('success'); });",
									"pm.test('data is an array', function () { pm.expect(json.data).to.be.an('array'); });"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/products.php",
							"host": [ "{{baseUrl}}" ],
							"path": [ "products.php" ]
						}
					}
				},
				{
					"name": "Get single product",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var json = pm.response.json();",
									"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
									"pm.test('has status field', function () { pm.expect(json).to.have.property('status'); });"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/products.php?id={{productId}}",
							"host": [ "{{baseUrl}}" ],
							"path": [ "products.php" ],
							"query": [ { "key": "id", "value": "{{productId}}" } ]
						}
					}
				},
				{
					"name": "Create product",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var json = pm.response.json();",
									"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
									"pm.test('status is success', function () { pm.expect(json.status).to.eql('success'); });",
									"if (json.product_id) { pm.collectionVariables.set('productId', json.product_id); }"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Postman Test Product\",\n    \"description\": \"Created from Postman\",\n    \"price\": 99.99,\n    \"quantity\": 10,\n    \"category\": \"Electronics\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/products.php",
							"host": [ "{{baseUrl}}" ],
							"path": [ "products.php" ]
						},
						"description": "Creates a product and stores its id into the {{productId}} collection variable for the Update/Delete/Get-single requests."
					}
				},
				{
					"name": "Update product",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var json = pm.response.json();",
									"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
									"pm.test('status is success', function () { pm.expect(json.status).to.eql('success'); });"
								]
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Updated Product Name\",\n    \"price\": 149.99\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/products.php?id={{productId}}",
							"host": [ "{{baseUrl}}" ],
							"path": [ "products.php" ],
							"query": [ { "key": "id", "value": "{{productId}}" } ]
						}
					}
				},
				{
					"name": "Delete product",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var json = pm.response.json();",
									"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
									"pm.test('status is success', function () { pm.expect(json.status).to.eql('success'); });"
								]
							}
						}
					],
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/products.php?id={{productId}}",
							"host": [ "{{baseUrl}}" ],
							"path": [ "products.php" ],
							"query": [ { "key": "id", "value": "{{productId}}" } ]
						}
					}
				},
				{
					"name": "Create product - invalid (negative price)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var json = pm.response.json();",
									"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
									"pm.test('validation rejects negative price', function () { pm.expect(json.status).to.eql('error'); });"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Invalid Product\",\n    \"price\": -50,\n    \"quantity\": 5,\n    \"category\": \"Electronics\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/products.php",
							"host": [ "{{baseUrl}}" ],
							"path": [ "products.php" ]
						},
						"description": "Negative price must be rejected by server-side validation."
					}
				}
			]
		}
	]
}
